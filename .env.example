# Client-side environment variables (exposed to browser)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_API_URL="http://localhost:5000"  # URL of your backend server
APP_URL="https://stonesightai.xyz"

# Server-only environment variables (NEVER expose these to client)
# Add these to .env file (not .env.example for security)
NVIDIA_API_KEY="your-nvidia-enterprise-api-key"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-if-needed"
CLIENT_URL="http://localhost:3000"
PORT=5000

# fal.ai API (for video generation)
FAL_API_KEY="your-fal-ai-api-key"

# Tripo 3D API (for 3D model generation)
TRIPO_API_KEY="your-tripo-api-key"
TRIPO_API_URL="https://api.tripo3d.ai/v2/openapi"